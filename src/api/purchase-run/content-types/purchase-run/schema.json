{
  "kind": "collectionType",
  "collectionName": "purchase_runs",
  "info": {
    "singularName": "purchase-run",
    "pluralName": "purchase-runs",
    "displayName": "Compra",
    "description": "Una lista de compra de un proveedor para una fecha determinada."
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "date": { "type": "date", "required": true },
    "status": {
      "type": "enumeration",
      "enum": ["draft", "open", "complete", "cancelled"],
      "default": "open",
      "required": true
    },
    "totalEstimated": { "type": "decimal", "default": 0, "min": 0 },
    "supplier": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supplier.supplier",
      "inversedBy": "purchaseRuns"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::purchase-run-item.purchase-run-item",
      "mappedBy": "purchaseRun"
    }
  }
}
