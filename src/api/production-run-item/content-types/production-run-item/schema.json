{
  "kind": "collectionType",
  "collectionName": "production_run_items",
  "info": {
    "singularName": "production-run-item",
    "pluralName": "production-run-items",
    "displayName": "Renglón de producción",
    "description": "Lotes y estado de un producto dentro de una jornada de producción."
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "batches": { "type": "integer", "required": true, "default": 0, "min": 0 },
    "batchSizeSnapshot": { "type": "string", "required": true },
    "completed": { "type": "boolean", "default": false },
    "completedAt": { "type": "datetime" },
    "productionRun": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::production-run.production-run",
      "inversedBy": "items"
    },
    "productionItem": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::production-item.production-item",
      "inversedBy": "productionRunItems"
    }
  }
}
