{
  "kind": "collectionType",
  "collectionName": "checklist_tasks",
  "info": {
    "singularName": "checklist-task",
    "pluralName": "checklist-tasks",
    "displayName": "Tarea de checklist",
    "description": "Tarea independiente del Daily Checklist."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "scheduledFor": {
      "type": "date",
      "required": true
    },
    "interval": {
      "type": "integer",
      "min": 1
    },
    "lastDone": {
      "type": "date"
    },
    "alternatesShifts": {
      "type": "boolean",
      "default": false
    },
    "previousShift": {
      "type": "enumeration",
      "enum": [
        "servicio",
        "producción",
        "servicio y producción"
      ]
    },
    "currentShift": {
      "type": "enumeration",
      "enum": [
        "servicio",
        "producción",
        "servicio y producción"
      ]
    },
    "taskStatus": {
      "type": "enumeration",
      "enum": [
        "vencida",
        "hoy",
        "proxima",
        "terminada",
        "servicio terminada",
        "producción terminada",
        "revisada"
      ],
      "default": "hoy",
      "required": true
    },
    "taskType": {
      "type": "enumeration",
      "enum": [
        "interval",
        "weekdays"
      ],
      "default": "interval",
      "required": true
    },
    "frecuency": {
      "type": "enumeration",
      "enum": [
        "weekly",
        "biweekly",
        "monthly"
      ]
    },
    "weekdays": {
      "type": "integer",
      "min": 1,
      "max": 7
    }
  }
}
