{
  "kind": "collectionType",
  "collectionName": "production_runs",
  "info": {
    "singularName": "production-run",
    "pluralName": "production-runs",
    "displayName": "Jornada de producción",
    "description": "Producción de un área en una fecha determinada."
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "date": { "type": "date", "required": true },
    "status": {
      "type": "enumeration",
      "enum": ["draft", "open", "complete"],
      "default": "draft",
      "required": true
    },
    "productionArea": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::production-area.production-area",
      "inversedBy": "productionRuns"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::production-run-item.production-run-item",
      "mappedBy": "productionRun"
    }
  }
}
