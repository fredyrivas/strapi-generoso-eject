{
  "kind": "collectionType",
  "collectionName": "purchase_run_items",
  "info": {
    "singularName": "purchase-run-item",
    "pluralName": "purchase-run-items",
    "displayName": "Renglón de compra",
    "description": "Cantidades y estado de un producto dentro de una compra."
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "serviceQty": { "type": "integer", "default": 0, "min": 0 },
    "productionQty": { "type": "integer", "default": 0, "min": 0 },
    "purchased": { "type": "boolean", "default": false },
    "unitCostSnapshot": { "type": "decimal", "default": 0, "min": 0 },
    "item": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::purchase-item.purchase-item",
      "inversedBy": "purchaseRunItems"
    },
    "purchaseRun": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::purchase-run.purchase-run",
      "inversedBy": "items"
    }
  }
}
